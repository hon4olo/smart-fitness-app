import AsyncStorage from '@react-native-async-storage/async-storage';
import {
  createContext,
  PropsWithChildren,
  useCallback,
  useContext,
  useEffect,
  useMemo,
  useState,
} from 'react';

export type Workout = {
  id: string;
  title: string;
  duration: string;
  exercises: Exercise[];
};

export type Exercise = {
