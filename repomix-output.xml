  carbs: number;
  fats: number;
  source: 'manual' | 'fatsecret' | 'openfoodfacts' | 'usda';
  externalId?: string;
  servingSize?: number;
  servingUnit?: string;
  quantity?: number;
  createdAt: string;
};

export type NutritionState = {
  calories: number;
  protein: number;
